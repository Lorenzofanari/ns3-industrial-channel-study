# --- Build artefacts ----------------------------------------------------
build/
*.o
*.obj
*.a
*.so
*.dylib
*.dll

# --- Python caches ------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Simulation outputs -------------------------------------------------
# Everything under results/ is regenerated by the campaign scripts; keep the
# directory under version control via the .gitkeep marker so a fresh clone
# still has a writeable target.
results/*
!results/.gitkeep

# Top-level ad-hoc artefacts that occasionally land in the repo root only.
# Subdirectories (configs/, data/, scripts/, src/) are NOT affected by these
# globs because the leading "/" pins them to the repository root.
/*.csv
/*.json
/*.log
*.out
*.tmp
*.pid

# Compressed campaign archives are reproducible from `scripts/run_sweep.py`
# and bloat the repository; keep them out of version control.
*.zip
*.tar.gz
*.tgz
*.7z

# --- LaTeX manuscript intermediates (manuscript itself may live in a sibling
#     directory; the entries below cover that case if the .tex tree is added
#     here in the future). -----------------------------------------------
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.toc

# --- Editor / IDE state -------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
